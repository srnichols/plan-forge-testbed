{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/session-start.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/session-start.ps1",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/check-forbidden.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/check-forbidden.ps1",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/post-edit-format.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/post-edit-format.ps1",
        "timeout": 15
      },
      {
        "type": "command",
        "command": ".github/hooks/scripts/post-edit-validate.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/post-edit-validate.ps1",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/stop-check-tests.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/stop-check-tests.ps1",
        "timeout": 10
      }
    ]
  }
}
