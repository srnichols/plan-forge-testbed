{
    // ─── GitHub Copilot Settings ───────────────────────────────────────
    // Recommended VS Code settings for the Plan Forge Pipeline.
    // Copy this file to .vscode/settings.json in your project root.

    // Enable Copilot Chat agent mode (required for execution pipeline)
    "github.copilot.chat.agent.enabled": true,

    // Allow pipeline agents to invoke each other as nested subagents (single-session pipeline).
    // Remove or set to false to require manual handoff button clicks between pipeline agents.
    "chat.subagents.allowInvocationsFromSubagents": true,

    // Point Copilot to your instruction files for inline suggestions
    "github.copilot.chat.codeGeneration.instructions": [
        { "file": ".github/instructions/architecture-principles.instructions.md" },
        { "file": ".github/instructions/git-workflow.instructions.md" }
        // Add your domain-specific instruction files here (12 available per preset):
        // { "file": ".github/instructions/database.instructions.md" },
        // { "file": ".github/instructions/testing.instructions.md" },
        // { "file": ".github/instructions/security.instructions.md" },
        // { "file": ".github/instructions/deploy.instructions.md" },
        // { "file": ".github/instructions/caching.instructions.md" },
        // { "file": ".github/instructions/messaging.instructions.md" },
        // { "file": ".github/instructions/observability.instructions.md" },
        // { "file": ".github/instructions/api-patterns.instructions.md" },
        // { "file": ".github/instructions/errorhandling.instructions.md" },
        // { "file": ".github/instructions/performance.instructions.md" },
        // { "file": ".github/instructions/multi-environment.instructions.md" },
        // { "file": ".github/instructions/version.instructions.md" }
    ],

    // Point Copilot to your test generation conventions
    "github.copilot.chat.testGeneration.instructions": [
        // { "file": ".github/instructions/testing.instructions.md" }
    ],

    // ─── Editor Settings for Plan Files ────────────────────────────────

    // Wrap markdown at 100 characters for readability
    "[markdown]": {
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 100,
        "editor.rulers": [100]
    },

    // ─── File Associations ─────────────────────────────────────────────

    // Ensure instruction files are treated as markdown
    "files.associations": {
        "*.instructions.md": "markdown",
        "*.prompt.md": "markdown",
        "*.agent.md": "markdown",
        "SKILL.md": "markdown"
    },

    // ─── Search Exclusions ─────────────────────────────────────────────
    // Hide template scaffolding from search after setup is complete
    // Uncomment these after running setup.ps1/setup.sh:
    //
    // "search.exclude": {
    //     "presets/": true,
    //     "templates/": true
    // }
}
